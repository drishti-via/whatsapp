generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://user@localhost:5432/viadb?schema=public"
}

model Chat {
  id           Int       @id @default(autoincrement())
  name         String
  lastMessage  String
  timeLabel    String
  unreadCount  Int       @default(0)
  avatarColor  String
  status       String
  phone        String
  messages     Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  chatId     Int
  chat       Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  body      String
  sentAt    DateTime
  isOwn     Boolean   @default(false)
  status    String
}
